public class PinValidator {

  public static boolean isPinValid(String pin) {
    if (pin == null || pin.length() != 6) {
      return false;
    }

    // invalid if all digits are the same
    char first = pin.charAt(0);
    for (int i = 1; i < pin.length(); i++) {
      if (pin.charAt(i) != first) {
        return true;
      }
    }

    return false;
  }
}
